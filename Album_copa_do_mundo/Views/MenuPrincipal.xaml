<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Album_copa_do_mundo.Views.MenuPrincipal"
             Title="MenuPrincipal">
    
    <FlexLayout Direction="Column" JustifyContent="SpaceBetween" Padding="20">
        <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
            <Image Source="copa2026_logo.png" HeightRequest="150" />
            <Label Text="Álbum Copa 2026" FontSize="28" FontAttributes="Bold" TextColor="#1A1A1A" HorizontalOptions="Center"/>
        </VerticalStackLayout>

        <VerticalStackLayout Spacing="20" HorizontalOptions="Fill">
            <Button Text="Cadastrar Figurinha" Clicked="OnCadastroClicked" BackgroundColor="#0033A0" TextColor="White" CornerRadius="10" HeightRequest="50"/>
            <Button Text="Minha Coleção" Clicked="OnListaClicked" BackgroundColor="#E3000F" TextColor="White" CornerRadius="10" HeightRequest="50"/>
        </VerticalStackLayout>

        <VerticalStackLayout HorizontalOptions="Center">
            <Label Text="v1.0.0" FontSize="12" TextColor="Gray" HorizontalOptions="Center"/>
            <Label Text="Desenvolvido por: [Seus Nomes]" FontSize="12" TextColor="Gray" HorizontalOptions="Center"/>
        </VerticalStackLayout>
    </FlexLayout>
    
</ContentPage>